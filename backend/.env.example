# Copy this to .env and fill in your values

# Set to true to route requests through the real EKX API
LIVE_MODE=false

# EKX API endpoint — inspect the network tab in ekx.cloud.sap to find the exact URL
EKX_API_URL=https://ekx.cloud.sap/api/v1/chat

# Auth token or API key for EKX
EKX_API_KEY=your-key-here
